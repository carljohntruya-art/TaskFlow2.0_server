PORT=5000
NODE_ENV=development
DATABASE_URL=postgresql://user:password@host:port/dbname
JWT_SECRET=replace_with_a_long_random_secret_at_least_64_chars
JWT_EXPIRES_IN=7d
# Comma-separated list of allowed frontend origins (no spaces)
FRONTEND_ORIGIN=https://your-app.vercel.app
COOKIE_SAME_SITE=none

# Admin seeder credentials (used by: npm run seed:admin)
ADMIN_EMAIL=admin@taskflow.com
ADMIN_PASSWORD=Admin@123456
